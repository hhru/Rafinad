/documentation\/Rafinad\/TestingElement","isActive":true,"type":"reference"},{"text":", например:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Accessibility-схема компонента со списком","class TagsAccessibility: ViewAccessibility {","","    let items = [TextAccessibility]()","}","","\/\/ Получение и проверка элемента списка по его индексу в тестах","tags","    .items[0] \/\/ получение тега по его индексу","    .assert(text: \"iOS\") \/\/ проверка текста тега","","\/\/ Получение и проверка элемента списка по его уточняющей строке в тестах","tags","    .items[\"iOS\"] \/\/ получение тега по его уточняющей строке","    .assert(text: \"iOS\") \/\/ проверка текста тега"],"type":"codeListing"},{"inlineContent":[{"text":"Чтобы получать элементы списка по уточняющей строке в тестах,","type":"text"},{"text":" ","type":"text"},{"text":"эта строка должна быть предварительно установлена вместе с accessibility-ключом, например:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ Компонент, который отображает список тегов","struct Tags: View {","","    let items: [String]","","    var body: some View {","        HStack(spacing: 8) {","            ForEach(items, id: \\.self) { tag in","                Text(tag)","                    .font(.subheadline)","                    .padding(8)","                    .background(.quinary)","                    .clipShape(.rect(cornerRadius: 8))","                    \/\/ Установка ключа для элемента списка с его уточнением","                    .accessibilityKey(\\TagsAccessibility.items, item: tag)","            }","        }","        .accessibilityElement(children: .contain)","    }","}"]},{"inlineContent":[{"text":"Такое уточнение элемента не требуется, если в тестах достаточно получать элементы списка по их индексу.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/ru.hh.Rafinad\/s8CopyableP","doc