ity-схемы, наделяющий UI-компоненты возможностью"},{"type":"text","text":" "},{"type":"text","text":"выполнять жесты поворота двумя касаниями в тестах."}],"kind":"symbol","title":"RotatableAccessibility"},"doc://ru.hh.Rafinad/documentation/Rafinad/DisableableAccessibility":{"identifier":"doc:\/\/ru.hh.Rafinad\/documentation\/Rafinad\/DisableableAccessibility","title":"DisableableAccessibility","type":"topic","url":"\/documentation\/rafinad\/disableableaccessibility","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DisableableAccessibility","kind":"identifier"}],"navigatorTitle":[{"text":"DisableableAccessibility","kind":"identifier"}],"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Протокол для accessibility-схемы, наделяющий UI-компоненты возможностью"},{"type":"text","text":" "},{"type":"text","text":"обрабатывать отключенное состояние в тестах."}]},"doc://ru.hh.Rafinad/documentation/Rafinad/ViewAccessibility":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ViewAccessibility","kind":"identifier"}],"url":"\/documentation\/rafinad\/viewaccessibility","type":"topic","abstract":[{"type":"text","text":"Базовая accessibility-схема для всех UI-компонентов."}],"kind":"symbol","title":"ViewAccessibility","role":"symbol","identifier":"doc:\/\/ru.hh.Rafinad\/documentation\/Rafinad\/ViewAccessibility","navigatorTitle":[{"text":"ViewAccessibility","kind":"identifier"}]},"doc://ru.hh.Rafinad/documentation/Rafinad/ScreenAccessibility":{"url":"\/documentation\/rafinad\/screenaccessibility","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ScreenAccessibility","kind":"identifier"}],"kind":"symbol","title":"ScreenAccessibility","type":"topic","identifier":"doc:\/\/ru.hh.Rafinad\/documentation\/Rafinad\/ScreenAccessibility","role":"symbol","abstract":[{"type":"text","text":"Accessibility-схема экрана."}],"navigatorTitle":[{"text":"ScreenAccessibility","kind":"